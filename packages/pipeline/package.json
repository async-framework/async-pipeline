{
  "name": "@async/pipeline",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "default": "./dist/core.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./lima": {
      "types": "./dist/lima.d.ts",
      "default": "./dist/lima.js"
    }
  },
  "bin": {
    "async-pipeline": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@async/pipeline-adapter-lima": "workspace:*",
    "@async/pipeline-core": "workspace:*",
    "@async/pipeline-node": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  }
}
